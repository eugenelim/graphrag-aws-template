# Local install-time scratch — written by `agentbundle install`,
# consumed by the adapt-to-project skill at session start. The path
# *is* the scope (repo-scope marker only here — user-scope marker
# lives inside ~/.agentbundle/, outside any repo).
.adapt-install-marker.toml

# Work-loop session state — per-spec scratch, never committed.
docs/specs/**/state.json

# Supervisor-mode worktrees.
.worktrees/

# Implementer reports — session-scratch.
docs/specs/**/notes/implementer-*.md

# Personal Claude Code overrides.
CLAUDE.local.md
.claude/settings.local.json
AGENTS.local.md

# OS / editor noise.
.DS_Store
*.swp
.vscode/
.idea/

# Python build artefacts.
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Python virtualenvs.
.venv/
venv/

# Test / type / lint caches.
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Per-deployer infra config (BUDGET_EMAIL / role ARN etc.) -- never committed.
# Anchored path: the committed config.env and config.local.env.example stay tracked.
apps/infra/scripts/config.local.env

# AWS CDK synth output.
apps/infra/cdk.out/
cdk.out/

# Terraform (apps/infra-tf/) — provider cache and real backend config are local-only.
# .terraform.lock.hcl IS committed (provider version pins).
apps/infra-tf/.terraform/
apps/infra-tf/backend.hcl
apps/infra-tf/*.tfvars
apps/infra-tf/*.tfstate
apps/infra-tf/*.tfstate.*
*.tfstate
*.tfstate.*

# Node (cdk CLI).
node_modules/

# Conductor scratch + per-workspace probe scaffolding.
.context/

# work-loop plan-verification scratch (local backend, never committed)
apps/infra-tf/backend_override.tf
