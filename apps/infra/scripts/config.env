# shellcheck shell=bash
# config.env -- build parameters & resource names for the GraphRAG slice stack.
#
# The single declarative source of everything the deploy/destroy/status scripts can
# be tuned by. Sourced by _aws-env.sh AFTER config.local.env (if present), using the
# assign-if-unset form `: "${VAR:=default}"`, so precedence is:
#
#     explicit env var  >  config.local.env  >  this file
#
# Note: `:=` treats an *empty* env var the same as unset, so `STACK= scripts/deploy.sh`
# falls through to the default -- export a real value to override, not an empty string.
#
# This file is EXECUTED (sourced), not parsed as data: every line must be a comment
# or a `: "${VAR:=...}"` assignment. NO logic, NO `aws` calls, NO branching -- those
# live in the scripts. $INFRA_DIR is set by _aws-env.sh before this file is sourced.

# --- Resource names --------------------------------------------------------
: "${STACK:=GraphragSlice1}"                  # CloudFormation stack name

# --- Region (account is derived live in _aws-env.sh) -----------------------
# This file owns the full region fallback chain; _aws-env.sh only exports AWS_REGION.
: "${AWS_REGION:=${AWS_DEFAULT_REGION:-us-east-1}}"

# --- Governance tag defaults (the User tag is filled from caller identity) -
: "${DEPLOY_ENV:=demo}"
: "${DEPLOY_DEPARTMENT:=unspecified}"
: "${DEPLOY_APPLICATION:=graphrag}"

# --- Operational knobs -----------------------------------------------------
: "${CREDS_CACHE:=${TMPDIR:-/tmp}/gr-aws-creds.env}"  # mode-600 session cred cache; kept OUTSIDE the repo tree
: "${CREDS_MAX_AGE_MIN:=50}"                          # refresh the cred cache when older than this (session tokens ~1h)
: "${VENV:=$INFRA_DIR/../../.venv}"                   # project virtualenv
: "${CDK_APP:=$VENV/bin/python $INFRA_DIR/app.py}"    # the `cdk --app` command
: "${DEPLOY_OUTPUTS_FILE:=$INFRA_DIR/cdk.out/deploy-outputs.json}"  # under the gitignored cdk.out/
# Service-linked roles an OpenSearch VPC domain needs pre-created (space-separated;
# consumed by an intentional word-split: `for svc in $OPENSEARCH_SLR_SERVICES`).
: "${OPENSEARCH_SLR_SERVICES:=opensearchservice.amazonaws.com es.amazonaws.com}"

# --- Per-deploy values (no safe default) -----------------------------------
# These are intentionally COMMENTS, never live assignments, so deploy.sh's
# `: "${BUDGET_EMAIL:?}"` guard stays the enforcement point and no placeholder can
# flow into a real deploy. Set them in config.local.env (gitignored) or inline:
#
#   BUDGET_EMAIL=you@example.com                       # REQUIRED: Budgets alarm subscriber
#   INVOKER_ROLE_ARN=arn:aws:iam::<acct>:role/<role>   # defaults to the deploying caller's role
#   S3_PREFIX_LIST_ID=pl-xxxxxxxx                       # resolved per-region by deploy.sh; override to pin
